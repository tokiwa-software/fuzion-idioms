ex100 is

  items := [ "siebenundvierzig";
             "elf";
             "null";
             "acht";
             "fünfzehn" ]

  c (String, String) -> bool := a,b -> a.byte_count <= b.byte_count
  say (items.sort_by c)

  # passing the lambda directly to sort avoids
  # specifying its type:
  #
  say (items.sort_by (a,b -> a.byte_count <= b.byte_count))
