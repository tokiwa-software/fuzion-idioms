ex100 is

  items := [ "siebenundvierzig";
             "elf";
             "null";
             "acht";
             "fünfzehn" ]

  c String -> i32 := .byte_count
  say (items.sort_by c)

  # passing the lambda directly to sort avoids
  # specifying its type:
  #
  say (items.sort_by (.byte_count))
